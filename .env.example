# Configuración de Base de Datos
DB_HOST=mysql
DB_NAME=trabajo_final_php
DB_USER=app_user
DB_PASS=app_password

# Configuración de la Aplicación
APP_ENV=production
APP_DEBUG=false

# Configuración de MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=trabajo_final_php
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# Configuración de Prometheus
PROMETHEUS_RETENTION=15d
PROMETHEUS_SCRAPE_INTERVAL=15s

# Configuración de Grafana
# Credenciales para acceder a Grafana en http://localhost:3000
# Usuario por defecto: admin
GRAFANA_ADMIN_USER=admin
# Contraseña por defecto: admin123
# ⚠️ IMPORTANTE: Cambia esta contraseña en producción
GRAFANA_ADMIN_PASSWORD=admin123

# Alertas (Alertmanager - email)
# Destinatario(s) de alertas. Puedes usar una lista separada por comas.
ALERT_EMAIL_TO=tuemail@dominio.com

# SMTP (ejemplos: smtp.gmail.com:587, smtp.office365.com:587, smtp.sendgrid.net:587;
# Amazon SES: email-smtp.<region>.amazonaws.com:587)
SMTP_SMARTHOST=smtp.gmail.com:587
SMTP_FROM=monitoring@tallermecanico.com
SMTP_AUTH_USERNAME=monitoring@tallermecanico.com
SMTP_AUTH_PASSWORD=CAMBIAR_ESTA_CLAVE
SMTP_REQUIRE_TLS=true

# Puertos
WEB_PORT=8081
MYSQL_PORT=3306

# --- Monitorización (puertos) ---
# Estos puertos SOLO aplican al despliegue local con `docker-compose.yml` (host:puerto -> contenedor).
# En Coolify se recomienda NO publicar puertos fijos al host: accede a Grafana/Prometheus/Alertmanager
# mediante dominios/rutas de Coolify hacia los puertos internos (3000/9090/9093).
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERTMANAGER_PORT=9093
BLACKBOX_EXPORTER_PORT=9115

# cAdvisor (docker-compose.yml): ghcr.io/google/cadvisor:$VERSION — VERSION sin prefijo v (ver README google/cadvisor Quick Start).
# CADVISOR_IMAGE_TAG=0.56.2

# Cloudflare Tunnel (opcional)
# Token del conector (se obtiene en Cloudflare Zero Trust → Tunnels).
# Usar solo si despliegas `cloudflared` (por ejemplo en `docker-compose.dokploy.yml`).
# CLOUDFLARE_TUNNEL_TOKEN=CAMBIAR_ESTE_TOKEN

# --- Simulador de tráfico (perfil Compose: traffic) ---
# Worker Apache JMeter + UI separados del panel admin. Primero cambia SIMULATOR_CONTROL_TOKEN en producción.
SIMULATOR_CONTROL_TOKEN=changeme_traffic_sim_secret
SIM_BASE_URL=http://web
TRAFFIC_SIMULATOR_UI_PORT=8890
SIM_UI_DEFAULT_BASE_URL=http://web
PROMETHEUS_EXTERNAL_URL=http://localhost:9090
GRAFANA_EXTERNAL_URL=http://localhost:3000
# Apache JMeter 5.6.3 (Java 8+). La imagen lo instala en build.
JMETER_VERSION=5.6.3
SIM_JMETER_HEAP="-Xms128m -Xmx256m -XX:MaxMetaspaceSize=128m"
SIM_JMETER_WORK_DIR=/var/www/html/logs/jmeter
SIM_JMETER_HTML_REPORT=true
# Opcional: CSS inyectado en el informe HTML de JMeter tras cada run (por defecto en la imagen traffic-simulator).
# SIM_JMETER_REPORT_CSS_SOURCE=/opt/traffic-simulator/assets/jmeter-report-custom.css
# Rutas opcionales JSON dentro del contenedor worker
# SIM_ROUTES_FILE=/var/www/html/conf/routes.json
SIM_INTERNAL_HOSTS=web,localhost,127.0.0.1,::1,mysql,taller_mecanico_web,host.docker.internal
SIM_EXTERNAL_TARGETS_ENABLED=true
SIM_REQUIRE_EXTERNAL_CONFIRMATION=true
SIM_ALLOW_PRIVATE_TARGETS=false
# SIM_SSL_VERIFY=false
