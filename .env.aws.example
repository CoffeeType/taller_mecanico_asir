# Copiar a .env en el servidor EC2 (no commitear secretos reales).
# Ver docs/AWS_DOCKER_DEPLOYMENT.md

# --- App ---
APP_ENV=production
APP_DEBUG=false

# --- Base de datos (rotar todo en produccion) ---
DB_NAME=trabajo_final_php
MYSQL_DATABASE=trabajo_final_php
MYSQL_USER=app_user
MYSQL_PASSWORD=CAMBIAR_APP_PASSWORD_FUERTE
MYSQL_ROOT_PASSWORD=CAMBIAR_ROOT_PASSWORD_FUERTE

# Host MySQL dentro del compose siempre es servicio "mysql"
MYSQL_HOST=mysql
MYSQL_PORT=3306

# --- Grafana (rotar) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CAMBIAR_GRAFANA_PASSWORD

# --- Alertas email (opcional) ---
ALERT_EMAIL_TO=
SMTP_SMARTHOST=
SMTP_FROM=
SMTP_AUTH_USERNAME=
SMTP_AUTH_PASSWORD=
SMTP_REQUIRE_TLS=true

# --- Puertos en el host EC2 ---
# HTTP publico (detras de ALB/Nginx o directo)
WEB_HOST_PORT=80

# Monitorizacion solo loopback: acceso por SSH tunnel o proxy local
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
ALERTMANAGER_HOST_PORT=9093

# Retencion Prometheus (debe coincidir con docker-compose.aws.yml)
PROMETHEUS_RETENTION=15d

# --- NO usar simulador de trafico en produccion publica sin firewall ---
# SIMULATOR_CONTROL_TOKEN=
