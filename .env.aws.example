# Copiar a .env en el servidor EC2 (no commitear secretos reales).
# Ver docs/AWS_DOCKER_DEPLOYMENT.md
#
# Stack por defecto: full (web + mysql + monitorizacion + simulador trafico).
# Instancia recomendada: t3.medium+ o al menos ~4 GB RAM+swap; ver MIN_* abajo.
# Modo degradado (solo web+mysql si poca RAM+swap): ALLOW_DEGRADED_STACK=1
#
# Primer despliegue: `deploy_aws_docker.sh` falla si quedan placeholders CAMBIAR_* / token debil.
# Laboratorio rapido: SKIP_SECRET_STRICT_CHECK=1 (no produccion).

# --- App ---
APP_ENV=production
APP_DEBUG=false

# --- Base de datos (rotar todo en produccion) ---
DB_NAME=trabajo_final_php
MYSQL_DATABASE=trabajo_final_php
MYSQL_USER=app_user
MYSQL_PASSWORD=CAMBIAR_APP_PASSWORD_FUERTE
MYSQL_ROOT_PASSWORD=CAMBIAR_ROOT_PASSWORD_FUERTE

# Host MySQL dentro del compose siempre es servicio "mysql"
MYSQL_HOST=mysql
MYSQL_PORT=3306

# --- Grafana (rotar) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CAMBIAR_GRAFANA_PASSWORD

# --- Perfiles Compose (full stack AWS) ---
DEPLOY_MONITORING=1
COMPOSE_PROFILES=monitoring,traffic

# Memoria minima RAM+swap (MB) para activar monitorizacion sin FORCE ni modo degradado
MIN_MONITORING_MEM_MB=3200
# Memoria minima RAM+swap (MB) para activar perfil traffic (simulador + UI)
MIN_TRAFFIC_STACK_MEM_MB=3600
# Si RAM+swap < MIN_* y no quieres fallar: FORCE_MONITORING_ON_LOW_MEM=1
FORCE_MONITORING_ON_LOW_MEM=0
# Si RAM+swap insuficiente y quieres solo web+mysql en lugar de error: ALLOW_DEGRADED_STACK=1
ALLOW_DEGRADED_STACK=0

# Saltar comprobacion de placeholders (solo lab/CI): SKIP_SECRET_STRICT_CHECK=1
SKIP_SECRET_STRICT_CHECK=0

# --- Alertas email (opcional) ---
ALERT_EMAIL_TO=
SMTP_SMARTHOST=
SMTP_FROM=
SMTP_AUTH_USERNAME=
SMTP_AUTH_PASSWORD=
SMTP_REQUIRE_TLS=true

# --- Puertos en el host EC2 ---
# HTTP publico (detras de ALB/Nginx o directo)
WEB_HOST_PORT=80

# Monitorizacion solo loopback: acceso por SSH tunnel
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
ALERTMANAGER_HOST_PORT=9093
CADVISOR_HOST_PORT=8080
TELEGRAF_HOST_PORT=9273

# cAdvisor: imagen oficial GHCR (README upstream). Tag = semver SIN prefijo v (ej. 0.56.2). Releases: https://github.com/google/cadvisor/releases
CADVISOR_IMAGE_TAG=0.56.2

# Simulador: UI en loopback (tunel SSH). Para exponer a red interna, quitar 127.0.0.1 en compose o usar SG.
TRAFFIC_SIMULATOR_UI_HOST_PORT=8890

# URLs que ve el navegador al usar tunel SSH (deben coincidir con host ports de arriba)
PROMETHEUS_EXTERNAL_URL=http://127.0.0.1:9090
GRAFANA_EXTERNAL_URL=http://127.0.0.1:3000

# Retencion Prometheus (debe coincidir con docker-compose.aws.yml)
PROMETHEUS_RETENTION=15d
PROMETHEUS_RETENTION_SIZE=512MB

# --- Simulador de trafico (perfil traffic) ---
# Obligatorio en produccion: token largo unico (deploy falla si queda changeme_* salvo SKIP_SECRET_STRICT_CHECK)
SIMULATOR_CONTROL_TOKEN=CAMBIAR_TOKEN_SIMULADOR_LARGO
SIM_BASE_URL=http://web
SIM_UI_DEFAULT_BASE_URL=http://web

# --- Recursos Docker (ajusta si la instancia es mayor) ---
WEB_MEM_LIMIT=512m
MYSQL_MEM_LIMIT=768m
PROMETHEUS_MEM_LIMIT=384m
GRAFANA_MEM_LIMIT=384m
ALERTMANAGER_MEM_LIMIT=128m
NODE_EXPORTER_MEM_LIMIT=96m
MYSQLD_EXPORTER_MEM_LIMIT=128m
BLACKBOX_EXPORTER_MEM_LIMIT=96m
CADVISOR_MEM_LIMIT=256m
TELEGRAF_MEM_LIMIT=256m
TRAFFIC_SIMULATOR_MEM_LIMIT=256m
TRAFFIC_SIMULATOR_UI_MEM_LIMIT=128m
